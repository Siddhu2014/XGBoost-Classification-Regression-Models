import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.impute import SimpleImputer
from xgboost import XGBRegressor
from sklearn.metrics import mean_absolute_error

# 1. LOAD DATA
df = pd.read_csv('train.csv')

# 2. SEPARATE TARGET AND FEATURES
X = df.drop(['SalePrice'], axis=1)
y = df.SalePrice

# Split into training and validation sets
# random_state ensures we get the same split every time we run it
X_train, X_test, y_train, y_test = train_test_split(
    X, y, train_size=0.8, test_size=0.2, random_state=42
)

# 3. FEATURE SELECTION (Numeric Only)
# XGBoost requires numbers. Here we isolate numeric columns to simplify preprocessing.
X_train_numeric = X_train.select_dtypes(exclude=['object'])
X_test_numeric = X_test.select_dtypes(exclude=['object'])

# 4. HANDLING MISSING VALUES (Imputation)
# SimpleImputer replaces missing values (NaN) with the mean of the column
my_imputer = SimpleImputer()

# IMPORTANT: fit_transform on TRAIN, but only transform on TEST.
# This prevents information from the test set 'leaking' into our training process.
imputed_X_train = pd.DataFrame(my_imputer.fit_transform(X_train_numeric))
imputed_X_test = pd.DataFrame(my_imputer.transform(X_test_numeric))

# Imputation removes column names; we must put them back
imputed_X_train.columns = X_train_numeric.columns
imputed_X_test.columns = X_test_numeric.columns

# 5. MODEL TRAINING
# n_estimators: 500 trees are usually enough for this dataset size
# learning_rate: 0.05 helps the model converge smoothly without overshooting
model = XGBRegressor(
    n_estimators=500, 
    learning_rate=0.05, 
    n_jobs=-1, # Optimized to use all CPU cores
    random_state=42
)

model.fit(imputed_X_train, y_train)

# 6. EVALUATION
preds = model.predict(imputed_X_test)

# Mean Absolute Error (MAE) shows the average dollar amount our predictions are off
mae = mean_absolute_error(y_test, preds)
print(f"XGBoost MAE: ${mae:,.2f}")
